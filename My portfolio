<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Mohammed Haneef | GIS & Mapping Operations</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Syne:wght@400;500;600;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
:root {
  --bg: #050b14;
  --bg2: #07111f;
  --card: #0c1a2e;
  --card2: #0f2040;
  --border: rgba(56,139,255,0.12);
  --border2: rgba(56,139,255,0.22);
  --blue: #388bff;
  --blue2: #6aabff;
  --gold: #e8b84b;
  --gold2: #f5d27a;
  --white: #f0f4ff;
  --muted: #7a9bb5;
  --dim: #3d5870;
  --glow: rgba(56,139,255,0.15);
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Syne',sans-serif;background:var(--bg);color:var(--white);overflow-x:hidden}

/* ── CURSOR ── */
.cursor{position:fixed;width:10px;height:10px;border-radius:50%;background:var(--blue);pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:transform 0.1s,width 0.3s,height 0.3s,opacity 0.3s;mix-blend-mode:screen}
.cursor-ring{position:fixed;width:36px;height:36px;border-radius:50%;border:1px solid rgba(56,139,255,0.5);pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:transform 0.15s ease-out,width 0.3s,height 0.3s}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:0 60px;height:64px;background:rgba(5,11,20,0.85);backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
.nav-logo{font-family:'Playfair Display',serif;font-size:20px;font-weight:700;color:var(--white);letter-spacing:0.5px}
.nav-logo em{color:var(--gold);font-style:italic}
.nav-links{display:flex;gap:36px;list-style:none}
.nav-links a{color:var(--muted);font-size:13px;font-weight:600;text-decoration:none;letter-spacing:0.08em;text-transform:uppercase;transition:color 0.2s;position:relative}
.nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:1px;background:var(--gold);transition:width 0.3s}
.nav-links a:hover{color:var(--white)}
.nav-links a:hover::after{width:100%}

/* ── HERO ── */
.hero{min-height:100vh;display:grid;grid-template-columns:1fr 1fr;align-items:center;padding:64px 60px 0;position:relative;overflow:hidden}
.hero-bg{position:absolute;inset:0;pointer-events:none}

/* Animated grid */
.grid-lines{position:absolute;inset:0;background-image:linear-gradient(rgba(56,139,255,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(56,139,255,0.04) 1px,transparent 1px);background-size:80px 80px}
.hero-orb{position:absolute;border-radius:50%;filter:blur(80px);pointer-events:none}
.orb1{width:600px;height:600px;background:radial-gradient(circle,rgba(56,139,255,0.12),transparent 70%);right:-100px;top:-100px}
.orb2{width:400px;height:400px;background:radial-gradient(circle,rgba(232,184,75,0.07),transparent 70%);left:100px;bottom:0}

.hero-left{position:relative;z-index:2;padding-right:40px}
.hero-eyebrow{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--blue2);letter-spacing:0.2em;text-transform:uppercase;margin-bottom:24px;opacity:0;animation:fadeUp 0.7s 0.1s forwards;display:flex;align-items:center;gap:12px}
.hero-eyebrow::before{content:'';width:32px;height:1px;background:var(--blue);display:inline-block}

.hero-name{font-family:'Playfair Display',serif;font-size:clamp(52px,6vw,80px);font-weight:900;line-height:1;margin-bottom:8px;opacity:0;animation:fadeUp 0.7s 0.2s forwards}
.hero-name span{display:block;color:var(--gold);font-style:italic}

.hero-designation{font-size:17px;font-weight:500;color:var(--muted);margin:20px 0 36px;line-height:1.6;opacity:0;animation:fadeUp 0.7s 0.35s forwards}
.hero-designation strong{color:var(--white)}

.hero-stats{display:flex;gap:36px;margin-bottom:44px;opacity:0;animation:fadeUp 0.7s 0.45s forwards}
.stat{text-align:center}
.stat-n{font-family:'Playfair Display',serif;font-size:38px;font-weight:700;color:var(--white);line-height:1}
.stat-n span{color:var(--gold)}
.stat-l{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--muted);letter-spacing:0.12em;text-transform:uppercase;margin-top:4px}

.hero-ctas{display:flex;gap:14px;opacity:0;animation:fadeUp 0.7s 0.55s forwards}
.btn{display:inline-flex;align-items:center;gap:8px;padding:13px 30px;font-family:'Syne',sans-serif;font-size:13px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;text-decoration:none;border-radius:2px;transition:all 0.25s;cursor:pointer;border:none}
.btn-gold{background:var(--gold);color:#050b14}
.btn-gold:hover{background:var(--gold2);transform:translateY(-2px);box-shadow:0 12px 32px rgba(232,184,75,0.25)}
.btn-ghost{background:transparent;color:var(--white);border:1px solid var(--border2)}
.btn-ghost:hover{border-color:var(--blue);color:var(--blue2);transform:translateY(-2px)}

/* Hero right — SVG map visual */
.hero-right{position:relative;z-index:2;opacity:0;animation:fadeIn 1.2s 0.6s forwards}
.map-frame{position:relative}
.map-frame svg{width:100%;filter:drop-shadow(0 20px 60px rgba(56,139,255,0.2))}

/* Floating chips */
.chip{position:absolute;background:rgba(12,26,46,0.95);border:1px solid var(--border2);padding:10px 16px;border-radius:3px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--blue2);backdrop-filter:blur(10px);white-space:nowrap;animation:float 3s ease-in-out infinite}
.chip::before{content:'▸';color:var(--gold);margin-right:6px}
.chip1{top:10%;right:-10px;animation-delay:0s}
.chip2{bottom:25%;right:-20px;animation-delay:1s}
.chip3{top:45%;left:-30px;animation-delay:0.5s}

/* scroll indicator */
.scroll-ind{position:absolute;bottom:32px;left:60px;display:flex;align-items:center;gap:12px;opacity:0;animation:fadeIn 1s 1.2s forwards}
.scroll-line{width:40px;height:1px;background:var(--dim)}
.scroll-txt{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--dim);letter-spacing:0.15em;text-transform:uppercase}

/* ── SHARED SECTION ── */
section{padding:100px 60px;position:relative}
.section-inner{max-width:1200px;margin:0 auto}
.sec-label{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--blue2);letter-spacing:0.2em;text-transform:uppercase;margin-bottom:12px;display:flex;align-items:center;gap:10px}
.sec-label::before{content:'';width:24px;height:1px;background:var(--blue)}
.sec-title{font-family:'Playfair Display',serif;font-size:clamp(36px,4vw,52px);font-weight:700;margin-bottom:8px;line-height:1.1}
.sec-title em{color:var(--gold);font-style:italic}
.sec-sub{font-size:15px;color:var(--muted);font-weight:400;margin-bottom:64px;max-width:560px}

/* ── ABOUT ── */
#about{background:var(--bg2)}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.about-text p{font-size:16px;line-height:1.85;color:var(--muted);margin-bottom:20px;font-weight:400}
.about-text p strong{color:var(--white);font-weight:600}
.about-text p em{color:var(--gold);font-style:italic}

.about-right{display:flex;flex-direction:column;gap:16px}
.attr-card{background:var(--card);border:1px solid var(--border);border-left:3px solid var(--gold);padding:20px 24px;border-radius:0 4px 4px 0;transition:border-color 0.2s,transform 0.2s}
.attr-card:hover{border-left-color:var(--blue);transform:translateX(4px)}
.attr-title{font-size:14px;font-weight:700;color:var(--white);margin-bottom:5px}
.attr-desc{font-size:13px;color:var(--muted);font-weight:400;line-height:1.6}

/* ── EXPERIENCE ── */
#experience{background:var(--bg)}
.exp-grid{display:grid;grid-template-columns:280px 1fr;gap:0}
.exp-nav{position:sticky;top:80px;height:fit-content;display:flex;flex-direction:column;gap:2px;padding-right:40px;border-right:1px solid var(--border)}
.exp-tab{padding:14px 18px;font-size:13px;font-weight:600;color:var(--dim);cursor:pointer;border-radius:3px 0 0 3px;transition:all 0.2s;border:none;background:none;text-align:left;border-right:2px solid transparent;margin-right:-1px;position:relative;z-index:1}
.exp-tab:hover{color:var(--muted);background:rgba(56,139,255,0.05)}
.exp-tab.active{color:var(--gold);background:rgba(232,184,75,0.06);border-right-color:var(--gold)}
.exp-tab .tab-co{display:block;font-size:11px;font-family:'JetBrains Mono',monospace;color:var(--dim);margin-top:3px;font-weight:400}
.exp-tab.active .tab-co{color:var(--muted)}

.exp-content{padding-left:48px}
.exp-panel{display:none}
.exp-panel.active{display:block}
.exp-role{font-family:'Playfair Display',serif;font-size:26px;font-weight:700;color:var(--white);margin-bottom:6px}
.exp-company{font-size:14px;font-weight:600;color:var(--blue2);margin-bottom:4px}
.exp-date{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--dim);margin-bottom:28px;letter-spacing:0.08em}
.exp-bullets{list-style:none;display:flex;flex-direction:column;gap:12px}
.exp-bullets li{font-size:15px;color:var(--muted);line-height:1.7;padding-left:20px;position:relative;font-weight:400}
.exp-bullets li::before{content:'▸';position:absolute;left:0;color:var(--gold);font-size:12px;top:3px}

/* ── PROJECTS ── */
#projects{background:var(--bg2)}
.projects-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border)}
.proj-card{background:var(--bg2);padding:36px 32px;position:relative;overflow:hidden;transition:background 0.3s;cursor:default}
.proj-card:hover{background:var(--card2)}
.proj-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--gold),var(--blue));transform:scaleX(0);transform-origin:left;transition:transform 0.4s}
.proj-card:hover::before{transform:scaleX(1)}
.proj-visual{width:100%;height:140px;margin-bottom:24px;border-radius:4px;overflow:hidden}
.proj-visual svg{width:100%;height:100%}
.proj-num{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--dim);letter-spacing:0.15em;margin-bottom:10px}
.proj-title{font-family:'Playfair Display',serif;font-size:20px;font-weight:700;color:var(--white);margin-bottom:10px;line-height:1.2}
.proj-desc{font-size:13px;color:var(--muted);line-height:1.7;font-weight:400;margin-bottom:16px}
.proj-tags{display:flex;flex-wrap:wrap;gap:6px}
.proj-tag{font-family:'JetBrains Mono',monospace;font-size:10px;padding:4px 10px;border:1px solid var(--border2);color:var(--blue2);border-radius:2px;letter-spacing:0.05em}

/* ── SKILLS ── */
#skills{background:var(--bg)}
.skills-layout{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
.skill-block{background:var(--card);border:1px solid var(--border);padding:32px 28px;border-radius:4px;transition:border-color 0.2s}
.skill-block:hover{border-color:var(--border2)}
.skill-block-title{font-size:12px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--gold);margin-bottom:20px;font-family:'JetBrains Mono',monospace}
.skill-rows{display:flex;flex-direction:column;gap:12px}
.skill-row-label{display:flex;justify-content:space-between;font-size:13px;color:var(--white);margin-bottom:6px;font-weight:500}
.skill-track{height:3px;background:var(--border);border-radius:2px;overflow:hidden}
.skill-fill{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--gold),var(--blue2));width:0;transition:width 1.4s cubic-bezier(0.4,0,0.2,1)}
.skill-tags-wrap{display:flex;flex-wrap:wrap;gap:8px;margin-top:8px}
.stag{font-family:'JetBrains Mono',monospace;font-size:11px;padding:6px 12px;background:rgba(56,139,255,0.07);border:1px solid var(--border);color:var(--blue2);border-radius:2px}

/* ── CONTACT ── */
#contact{background:var(--bg2);text-align:center}
.contact-inner{max-width:680px;margin:0 auto}
.contact-cards{display:flex;justify-content:center;gap:16px;flex-wrap:wrap;margin:48px 0}
.c-card{display:flex;align-items:center;gap:14px;background:var(--card);border:1px solid var(--border);padding:18px 28px;border-radius:3px;text-decoration:none;transition:all 0.2s;min-width:200px}
.c-card:hover{border-color:var(--gold);transform:translateY(-3px);box-shadow:0 12px 40px rgba(232,184,75,0.1)}
.c-icon{font-size:22px}
.c-info{text-align:left}
.c-label{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--dim);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:3px}
.c-val{font-size:14px;color:var(--white);font-weight:600}
.avail-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(232,184,75,0.1);border:1px solid rgba(232,184,75,0.3);padding:8px 20px;border-radius:100px;font-size:13px;color:var(--gold);font-weight:600;margin-bottom:32px}
.avail-dot{width:8px;height:8px;border-radius:50%;background:var(--gold);animation:pulse 2s infinite}

/* ── FOOTER ── */
footer{background:var(--bg);border-top:1px solid var(--border);padding:24px 60px;display:flex;justify-content:space-between;align-items:center}
.footer-copy{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--dim);letter-spacing:0.08em}

/* ── REVEAL ── */
.reveal{opacity:0;transform:translateY(32px);transition:opacity 0.7s,transform 0.7s}
.reveal.visible{opacity:1;transform:translateY(0)}
.reveal-left{opacity:0;transform:translateX(-32px);transition:opacity 0.7s,transform 0.7s}
.reveal-left.visible{opacity:1;transform:translateX(0)}
.reveal-right{opacity:0;transform:translateX(32px);transition:opacity 0.7s,transform 0.7s}
.reveal-right.visible{opacity:1;transform:translateX(0)}

/* ── ANIMS ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.5;transform:scale(0.6)}}
@keyframes scanline{0%{transform:translateY(-100%)}100%{transform:translateY(800%)}}
@keyframes dash{to{stroke-dashoffset:0}}
@keyframes ping{0%{transform:scale(1);opacity:1}100%{transform:scale(2.5);opacity:0}}

/* ── RESPONSIVE ── */
@media(max-width:960px){
  nav{padding:0 24px}
  .hero{grid-template-columns:1fr;padding:80px 24px 60px}
  .hero-right{display:none}
  section{padding:70px 24px}
  .about-grid,.exp-grid{grid-template-columns:1fr}
  .exp-nav{flex-direction:row;flex-wrap:wrap;border-right:none;border-bottom:1px solid var(--border);padding:0 0 16px}
  .exp-content{padding-left:0;padding-top:32px}
  .projects-grid{grid-template-columns:1fr}
  .skills-layout{grid-template-columns:1fr}
  footer{flex-direction:column;gap:12px;text-align:center;padding:24px}
}
</style>
</head>
<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- NAV -->
<nav>
  <div class="nav-logo">M.<em>Haneef</em></div>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#experience">Experience</a></li>
    <li><a href="#projects">Projects</a></li>
    <li><a href="#skills">Skills</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<!-- HERO -->
<section class="hero" id="home">
  <div class="hero-bg">
    <div class="grid-lines"></div>
    <div class="hero-orb orb1"></div>
    <div class="hero-orb orb2"></div>
  </div>

  <div class="hero-left">
    <div class="hero-eyebrow">GIS &amp; Mapping Operations Expert</div>
    <h1 class="hero-name">
      Mohammed
      <span>Haneef</span>
    </h1>
    <p class="hero-designation">
      <strong>Program Manager, Mapping Operations</strong><br/>
      Building high-quality geospatial data systems that power<br/>
      the next generation of autonomous mobility.
    </p>
    <div class="hero-stats">
      <div class="stat"><div class="stat-n">6<span>+</span></div><div class="stat-l">Years Experience</div></div>
      <div class="stat"><div class="stat-n">25<span>+</span></div><div class="stat-l">Team Led</div></div>
      <div class="stat"><div class="stat-n">7<span>+</span></div><div class="stat-l">Key Projects</div></div>
      <div class="stat"><div class="stat-n">3</div><div class="stat-l">Sectors Served</div></div>
    </div>
    <div class="hero-ctas">
      <a href="#projects" class="btn btn-gold">View My Work</a>
      <a href="#contact" class="btn btn-ghost">Get In Touch</a>
    </div>
  </div>

  <div class="hero-right">
    <div class="map-frame">
      <!-- Realistic GIS map SVG -->
      <svg viewBox="0 0 540 480" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <radialGradient id="bgGrad" cx="50%" cy="50%"><stop offset="0%" stop-color="#0f2040"/><stop offset="100%" stop-color="#050b14"/></radialGradient>
          <filter id="glow"><feGaussianBlur stdDeviation="2.5" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
          <filter id="glow2"><feGaussianBlur stdDeviation="4" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
          <clipPath id="mapClip"><rect width="540" height="480" rx="8"/></clipPath>
          <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(56,139,255,0.06)" stroke-width="0.5"/></pattern>
          <linearGradient id="roadGrad" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" stop-color="#388bff" stop-opacity="0.3"/><stop offset="50%" stop-color="#388bff" stop-opacity="0.8"/><stop offset="100%" stop-color="#388bff" stop-opacity="0.3"/></linearGradient>
          <linearGradient id="roadGrad2" x1="0%" y1="0%" x2="0%" y2="100%"><stop offset="0%" stop-color="#e8b84b" stop-opacity="0.3"/><stop offset="50%" stop-color="#e8b84b" stop-opacity="0.7"/><stop offset="100%" stop-color="#e8b84b" stop-opacity="0.3"/></linearGradient>
        </defs>
        <g clip-path="url(#mapClip)">
          <!-- Background -->
          <rect width="540" height="480" fill="url(#bgGrad)"/>
          <rect width="540" height="480" fill="url(#grid)"/>

          <!-- Water body -->
          <path d="M380,320 Q420,280 460,300 Q500,320 520,360 L540,380 L540,480 L380,480 Z" fill="rgba(20,60,120,0.5)" opacity="0.7"/>
          <path d="M390,330 Q430,295 465,310 Q498,328 515,365" fill="none" stroke="rgba(56,139,255,0.3)" stroke-width="0.8"/>

          <!-- Land parcels -->
          <rect x="40" y="40" width="120" height="80" rx="1" fill="rgba(30,80,40,0.35)" stroke="rgba(56,200,80,0.2)" stroke-width="0.8"/>
          <rect x="170" y="40" width="90" height="80" rx="1" fill="rgba(30,80,40,0.25)" stroke="rgba(56,200,80,0.15)" stroke-width="0.8"/>
          <rect x="40" y="130" width="80" height="70" rx="1" fill="rgba(30,80,40,0.3)" stroke="rgba(56,200,80,0.2)" stroke-width="0.8"/>
          <rect x="130" y="130" width="100" height="70" rx="1" fill="rgba(40,90,50,0.25)" stroke="rgba(56,200,80,0.15)" stroke-width="0.8"/>
          <rect x="240" y="60" width="100" height="90" rx="1" fill="rgba(40,60,100,0.3)" stroke="rgba(56,100,200,0.2)" stroke-width="0.8"/>
          <rect x="350" y="40" width="80" height="60" rx="1" fill="rgba(30,80,40,0.2)" stroke="rgba(56,200,80,0.15)" stroke-width="0.8"/>
          <rect x="440" y="40" width="80" height="100" rx="1" fill="rgba(40,60,100,0.25)" stroke="rgba(56,100,200,0.18)" stroke-width="0.8"/>

          <rect x="40" y="220" width="140" height="80" rx="1" fill="rgba(30,80,40,0.28)" stroke="rgba(56,200,80,0.15)" stroke-width="0.8"/>
          <rect x="190" y="220" width="90" height="80" rx="1" fill="rgba(60,40,100,0.25)" stroke="rgba(120,56,200,0.2)" stroke-width="0.8"/>
          <rect x="290" y="160" width="80" height="130" rx="1" fill="rgba(40,60,100,0.22)" stroke="rgba(56,100,200,0.15)" stroke-width="0.8"/>

          <rect x="40" y="320" width="100" height="100" rx="1" fill="rgba(30,80,40,0.22)" stroke="rgba(56,200,80,0.12)" stroke-width="0.8"/>
          <rect x="150" y="320" width="130" height="60" rx="1" fill="rgba(40,60,100,0.2)" stroke="rgba(56,100,200,0.12)" stroke-width="0.8"/>
          <rect x="150" y="390" width="130" height="60" rx="1" fill="rgba(30,80,40,0.2)" stroke="rgba(56,200,80,0.12)" stroke-width="0.8"/>

